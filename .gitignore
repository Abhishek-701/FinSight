# secrets
.env

# data (downloaded filings + vector store; reproducible via ingest)
# Ignore data/ contents (incl. data/raw/, data/parsed/) but keep the manifest and the
# serving artifacts (chunks, facts, chroma vector store) so Docker/Render can build
# directly from git without re-running ingest or re-embedding at deploy time.
data/*
!data/manifest.json
!data/chunks.json
!data/facts.json
!data/chroma/
!data/chroma/**

# python
__pycache__/
*.pyc
.venv/
venv/

# frontend
web/node_modules/
static/dist/

# eval response cache (disposable, regenerable — see eval/run_eval.py)
eval/.cache/
