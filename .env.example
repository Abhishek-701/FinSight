# Copy to .env and fill in. .env is gitignored (G6).

# OpenAI: used ONLY for embeddings (text-embedding-3-small).
# Anthropic has no embeddings API, so retrieval's dense half needs this.
OPENAI_API_KEY=sk-...

# Anthropic: used for the chat LLM (decomposition + synthesis), temperature 0.
ANTHROPIC_API_KEY=sk-ant-...
